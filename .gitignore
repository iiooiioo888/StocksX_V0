# ════════════════════════════════════════════════════════════
# 數據與緩存
# ════════════════════════════════════════════════════════════
/data/
cache/
!src/data/
*.db
*.sqlite
*.sqlite3
*.sqlite-wal
*.sqlite-shm

# ════════════════════════════════════════════════════════════
# 環境變數（⚠️ 絕不能提交）
# ════════════════════════════════════════════════════════════
.env
.env.*
!.env.example
.venv/
venv/

# ════════════════════════════════════════════════════════════
# Python 編譯檔
# ════════════════════════════════════════════════════════════
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# ════════════════════════════════════════════════════════════
# IDE
# ════════════════════════════════════════════════════════════
.idea/
.vscode/
*.swp
*.swo
*.sublime-*

# ════════════════════════════════════════════════════════════
# 日誌（⚠️ 可能含敏感資訊）
# ════════════════════════════════════════════════════════════
logs/
*.log
logs/**

# ════════════════════════════════════════════════════════════
# 系統文件
# ════════════════════════════════════════════════════════════
.DS_Store
Thumbs.db

# ════════════════════════════════════════════════════════════
# 模型檔案（ML / AI）
# ════════════════════════════════════════════════════════════
*.h5
*.pkl
*.joblib
*.onnx
*.pt
*.pth

# ════════════════════════════════════════════════════════════
# Docker
# ════════════════════════════════════════════════════════════
docker-compose.override.yml

# ════════════════════════════════════════════════════════════
# Node / OS
# ════════════════════════════════════════════════════════════
node_modules/
npm-debug.log*
