# ════════════════════════════════════════════════════════════
# StocksX V0 — 環境變數配置
# ════════════════════════════════════════════════════════════
# 複製此文件為 .env 並填入實際值
# cp .env.example .env

# ════════════════════════════════════════════════════════════
# 應用配置
# ════════════════════════════════════════════════════════════
APP_ENV=production
APP_DEBUG=false
APP_PORT=8501
WS_PORT=8001

# ⚠️⚠️⚠️ 必填：JWT 簽名密鑰（主應用和 WebSocket 必須共用同一把密鑰！）
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
# 未設定將導致認證失敗、WebSocket 連接斷開
SECRET_KEY=

# ⚠️ 必填：管理員密碼
# 未設定將自動生成隨機密碼（僅首次有效，重啟後變更）
ADMIN_PASSWORD=

# 時區
TZ=Asia/Shanghai

# 日誌級別
LOG_LEVEL=INFO

# CORS 允許的來源（逗號分隔）
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# WebSocket 認證 token（生產環境必填）
WS_AUTH_TOKEN=

# ════════════════════════════════════════════════════════════
# Redis 配置
# ════════════════════════════════════════════════════════════
REDIS_URL=redis://redis:6379/0

# ════════════════════════════════════════════════════════════
# 交易所 API（可選 — 用於自動交易）
# ════════════════════════════════════════════════════════════
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BYBIT_API_KEY=
BYBIT_SECRET_KEY=

# ════════════════════════════════════════════════════════════
# 第三方數據 API（可選）
# ════════════════════════════════════════════════════════════
DASHSCOPE_API_KEY=
COINGECKO_API_KEY=
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=

# ════════════════════════════════════════════════════════════
# 監控（可選 — 僅 monitoring profile 需要）
# ════════════════════════════════════════════════════════════
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# ════════════════════════════════════════════════════════════
# 推播通知（可選 — iOS Bark）
# ════════════════════════════════════════════════════════════
BARK_KEY=
BARK_SERVER=https://api.day.app
