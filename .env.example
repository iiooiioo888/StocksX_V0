# StocksX 環境變數配置範例
# 請複製此檔案為 .env 並填入實際值

# ════════════════════════════════════════════════════════════
# Redis 配置（任務隊列 + 快取）
# ════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0

# ════════════════════════════════════════════════════════════
# 資料庫配置（生產環境使用 PostgreSQL）
# ════════════════════════════════════════════════════════════
# SQLite（開發環境）
DATABASE_URL=sqlite:///cache/users.sqlite

# PostgreSQL（生產環境，取消註解並填寫）
# DATABASE_URL=postgresql://user:password@localhost:5432/stocksx

# ════════════════════════════════════════════════════════════
# Celery 配置
# ════════════════════════════════════════════════════════════
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TIMEZONE=Asia/Taipei

# ════════════════════════════════════════════════════════════
# 日誌配置
# ════════════════════════════════════════════════════════════
LOG_LEVEL=INFO
LOG_DIR=logs

# ════════════════════════════════════════════════════════════
# API 金鑰配置（請參照 config_secrets.py）
# ════════════════════════════════════════════════════════════
# Alpha Vantage
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# FRED
FRED_API_KEY=your_fred_key

# Polygon.io
POLYGON_API_KEY=your_polygon_key

# CoinGecko
COINGECKO_API_KEY=your_coingecko_key

# CoinMarketCap
COINMARKETCAP_API_KEY=your_coinmarketcap_key

# Glassnode
GLASSNODE_API_KEY=your_glassnode_key

# Trading Economics
TRADING_ECONOMICS_API_KEY=your_trading_economics_key

# FMP
FMP_API_KEY=your_fmp_key

# Alpaca
ALPACA_API_KEY=your_alpaca_key
ALPACA_API_SECRET=your_alpaca_secret

# CBOE
CBOE_API_KEY=your_cboe_key

# ════════════════════════════════════════════════════════════
# Streamlit 配置
# ════════════════════════════════════════════════════════════
STREAMlit_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# ════════════════════════════════════════════════════════════
# 應用配置
# ════════════════════════════════════════════════════════════
APP_ENV=development
# APP_ENV=production

# 限流配置（可選，預設值在 rate_limiter.py 中）
RATE_LIMIT_DEFAULT_CAPACITY=10
RATE_LIMIT_DEFAULT_REFILL_RATE=1.0
