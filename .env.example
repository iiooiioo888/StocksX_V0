# ════════════════════════════════════════════════════════════
# StocksX V0 - 环境变量配置
# ════════════════════════════════════════════════════════════
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ════════════════════════════════════════════════════════════
# 应用配置
# ════════════════════════════════════════════════════════════
APP_ENV=production
APP_DEBUG=false
APP_PORT=8501

# ⚠️ 必填：JWT 签名密钥（用于 WebSocket 认证），请使用随机长字符串
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ⚠️ 首次启动时创建管理员的密码（不设置则自动生成随机密码）
ADMIN_PASSWORD=

# ════════════════════════════════════════════════════════════
# 数据库配置（PostgreSQL）
# ════════════════════════════════════════════════════════════
POSTGRES_DB=stocksx
POSTGRES_USER=stocksx_user
# ⚠️ 重要：请修改为强密码（至少 16 位，包含大小写字母、数字、特殊字符）
POSTGRES_PASSWORD=你的强密码_至少 16 位

# ════════════════════════════════════════════════════════════
# Redis 配置
# ════════════════════════════════════════════════════════════
REDIS_URL=redis://redis:6379/0

# ════════════════════════════════════════════════════════════
# 数据库连接字符串（自动生成，通常不需要修改）
# ════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ════════════════════════════════════════════════════════════
# 交易所 API（可选，用于自动交易）
# ════════════════════════════════════════════════════════════
# 币安 API Key（https://www.binance.com/my/settings/api-management）
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Bybit API Key（https://www.bybit.com/settings/api）
BYBIT_API_KEY=
BYBIT_SECRET_KEY=

# ════════════════════════════════════════════════════════════
# 监控配置（可选）
# ════════════════════════════════════════════════════════════
GRAFANA_ADMIN_USER=admin
# ⚠️ 重要：请修改为强密码
GRAFANA_ADMIN_PASSWORD=

# ════════════════════════════════════════════════════════════
# 其他配置
# ════════════════════════════════════════════════════════════
# 日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）
LOG_LEVEL=INFO

# 最大连接数
MAX_CONNECTIONS=100

# 请求超时（秒）
REQUEST_TIMEOUT=30
