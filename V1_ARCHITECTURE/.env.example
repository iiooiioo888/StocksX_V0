# StocksX V1 環境變數配置範例

# ════════════════════════════════════════════════════════════
# 應用配置
# ════════════════════════════════════════════════════════════
APP_ENV=development
# APP_ENV=production

# ════════════════════════════════════════════════════════════
# 資料庫配置
# ════════════════════════════════════════════════════════════
# SQLite（開發環境）
DATABASE_URL=sqlite:///./stocksx.db

# PostgreSQL（生產環境）
# DATABASE_URL=postgresql://stocksx:your_password@localhost:5432/stocksx

POSTGRES_PASSWORD=stocksx_secure_password_change_me

# ════════════════════════════════════════════════════════════
# Redis 配置
# ════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0

# ════════════════════════════════════════════════════════════
# Celery 配置
# ════════════════════════════════════════════════════════════
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ════════════════════════════════════════════════════════════
# JWT 配置（生產環境務必修改）
# ════════════════════════════════════════════════════════════
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ════════════════════════════════════════════════════════════
# CORS 配置
# ════════════════════════════════════════════════════════════
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# ════════════════════════════════════════════════════════════
# 日誌配置
# ════════════════════════════════════════════════════════════
LOG_LEVEL=INFO
LOG_DIR=logs

# ════════════════════════════════════════════════════════════
# 伺服器配置
# ════════════════════════════════════════════════════════════
HOST=0.0.0.0
PORT=8000

# ════════════════════════════════════════════════════════════
# API 金鑰（可選）
# ════════════════════════════════════════════════════════════
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=
COINGECKO_API_KEY=
